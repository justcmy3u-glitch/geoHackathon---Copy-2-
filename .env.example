# === Colab GPU Tunnel ===
COLAB_TUNNEL_URL=https://your-cloudflare-tunnel-url.trycloudflare.com

# API key for authenticating requests to the Colab server
# Generate a random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
COLAB_API_KEY=changeme-generate-a-random-key

# === Security ===
# JWT signing secret for session tokens
JWT_SECRET=changeme-generate-a-random-jwt-secret

# === Database Credentials ===
POSTGRES_PASSWORD=password

# Neo4j credentials (must match docker-compose.yml)
NEO4J_AUTH=neo4j/password123
